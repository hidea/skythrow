---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy | SkyThrow" lang="en" path="/en/privacy-policy/">
  <section class="text-page">
    <p class="eyebrow">Privacy Policy</p>
    <h1>Privacy Policy</h1>
    <div class="policy-card">
      <p>This privacy policy applies to the SkyThrow mobile application created by rukari.com / hidea as a free service.</p>
      <p>The app may collect device information, usage information, operating system information, and related data for service operation and improvement. The app does not collect precise mobile device location information.</p>
      <p>The app uses third-party services such as Google Play Services and Bluesky, each of which has its own privacy policy.</p>
      <p>For privacy questions, contact <a href="mailto:support@rukari.com">support@rukari.com</a>.</p>
      <p>Effective: 2024.4.4</p>
    </div>
  </section>
</BaseLayout>
