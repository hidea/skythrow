---
import releases from "../data/releases.json";

const { lang = "ja", limit } = Astro.props;
const visible = typeof limit === "number" ? releases.slice(0, limit) : releases;
---

<div class="release-list">
  {
    visible.map((release) => (
      <article class="release-card">
        <div class="release-meta">
          <span class="pill">v{release.version}</span>
          <span class="pill">{release.date}</span>
          {release.platforms.map((platform) => (
            <span class="pill">{platform}</span>
          ))}
        </div>
        <h3>{release.title[lang]}</h3>
        <ul>
          {release.changes[lang].map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    ))
  }
</div>
