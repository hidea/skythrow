---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentPage from "../../components/ContentPage.astro";
import { loadLegacyMarkdown } from "../../lib/legacyContent.js";

const page = loadLegacyMarkdown("_pages/privacy-policy.markdown", { lang: "en" });
---

<BaseLayout title="Privacy Policy | SkyThrow" lang="en" path="/en/privacy-policy/">
  <ContentPage eyebrow="Privacy Policy" title={page.title || "Privacy Policy"} html={page.html} card />
</BaseLayout>
