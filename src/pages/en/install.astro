---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLatestRelease } from "../../lib/legacyContent.js";

const latest = getLatestRelease();
---

<BaseLayout title="Install | SkyThrow" lang="en" path="/en/install/">
  <section class="text-page">
    <p class="eyebrow">Install</p>
    <h1>Install</h1>
    <div class="version-status" aria-label={`Latest available version ${latest.version}`}>
      <span class="version-label">Latest version</span>
      <strong>ver.{latest.version}</strong>
      <span class="version-copy">Available for iOS and Android.</span>
    </div>
    <div class="store-panel">
      <article class="store-card">
        <img class="qr" src="/assets/images/google-play-qr-code.png" alt="Google Play QR code" />
        <a href="https://play.google.com/store/apps/details?id=com.rukari.skythrowApp">
          <img class="badge" src="/assets/images/google-play-badge.png" alt="Get it on Google Play" />
        </a>
      </article>
      <article class="store-card">
        <img class="qr" src="/assets/images/app-store-qr-code.png" alt="App Store QR code" />
        <a href="https://apps.apple.com/us/app/skythrow/id6478918510">
          <img class="badge" src="/assets/images/Download_on_the_App_Store_Badge.svg" alt="Download on the App Store" />
        </a>
      </article>
    </div>
  </section>
</BaseLayout>
